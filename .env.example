# ─── Meta / WhatsApp ───────────────────────────────────────────────────────────
# Token que vos elegís al configurar el webhook en Meta for Developers
META_VERIFY_TOKEN=tu_token_secreto_aqui

# Token permanente de Meta Cloud API (generado en Meta for Developers > WhatsApp > API Setup)
META_ACCESS_TOKEN=

# ID del número de WhatsApp Business en Meta for Developers > WhatsApp > API Setup
META_PHONE_NUMBER_ID=

# ─── OpenAI ────────────────────────────────────────────────────────────────────
# Clave de API de OpenAI (platform.openai.com/api-keys)
OPENAI_API_KEY=

# ─── MercadoLibre ──────────────────────────────────────────────────────────────
# Token de acceso de ML (developers.mercadolibre.com)
ML_ACCESS_TOKEN=

# ID del vendedor en ML (lo encontrás en tu perfil de vendedor)
ML_SELLER_ID=

# ─── Tienda Nube ───────────────────────────────────────────────────────────────
# Token de acceso de Tienda Nube (partners.tiendanube.com)
TN_ACCESS_TOKEN=

# ID numérico de tu tienda en Tienda Nube
TN_STORE_ID=

# ─── Chatwoot ──────────────────────────────────────────────────────────────────
# URL base de tu instancia de Chatwoot (ej: https://app.chatwoot.com)
CHATWOOT_BASE_URL=

# Token de API de Chatwoot (Settings > API Access Tokens)
CHATWOOT_API_TOKEN=

# ID del inbox de WhatsApp en Chatwoot (Settings > Inboxes)
CHATWOOT_INBOX_ID=

# ID de tu cuenta en Chatwoot (Settings > General Settings > Account ID, o en la URL: /app/accounts/X)
CHATWOOT_ACCOUNT_ID=

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development
